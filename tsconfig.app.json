{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@mcs/common/*": ["../mcs/common/src/*"],
      "@mcs/common": ["../mcs/common/src"],
      "@mcs/product-catalog/*": ["../mcs/product-catalog/src/*"],
      "@mcs/product-catalog": ["../mcs/product-catalog/src"],
      "common_remote/Button": ["../mcs/common/src/button"],
      "common_remote/Breadcrumbs": ["../mcs/common/src/breadcrumbs"],
      "common_remote/Dialog": ["../mcs/common/src/dialog"],
      "common_remote/Snackbar": ["../mcs/common/src/snackbar"],
      "common_remote/Paper": ["../mcs/common/src/paper"],
      "common_remote/AutoComplete": ["../mcs/common/src/autocomplete"],
      "common_remote/Select": ["../mcs/common/src/select"],
      "common_remote/TextField": ["../mcs/common/src/textfield"],
      "common_remote/Switch": ["../mcs/common/src/switch"],
      "common_remote/DataGrid": ["../mcs/common/src/datagrid"],
      "common_remote/Chip": ["../mcs/common/src/chip"],
      "common_remote/Typography": ["../mcs/common/src/typography"],
      "common_remote/Divider": ["../mcs/common/src/divider"],
      "common_remote/Alert": ["../mcs/common/src/alert"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
